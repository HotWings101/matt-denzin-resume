# ============================================================================
# Matt Denzin — AI-first résumé site · environment
# Copy to .env.local for local dev. In production these are set in Vercel.
# ============================================================================

# --- Supabase -------------------------------------------------------------
# Project URL + anon (publishable) key are safe for the browser (used only for
# admin Auth). The service role key is SERVER-ONLY and must never be exposed.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- AI (Vercel AI Gateway) ----------------------------------------------
# A single gateway key powers both chat (Claude) and embeddings (OpenAI).
# On Vercel this can be provided automatically via OIDC; locally set the key.
AI_GATEWAY_API_KEY=YOUR-VERCEL-AI-GATEWAY-KEY
CHAT_MODEL=anthropic/claude-sonnet-4-6
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Admin ----------------------------------------------------------------
# Comma-separated allowlist of emails permitted into /admin.
ADMIN_EMAILS=mattdenzin@yahoo.com

# --- Site -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
