# ============================================================================
# Matt Denzin — AI-first résumé site · environment
# Copy to .env.local for local dev. In production these are set in Vercel.
# ============================================================================

# --- Supabase -------------------------------------------------------------
# Project URL + anon (publishable) key are safe for the browser (used only for
# admin Auth). The service role key is SERVER-ONLY and must never be exposed.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- AI (Google Gemini) ---------------------------------------------------
# One Gemini API key powers chat, the JD analyzer, and embeddings.
GOOGLE_GENERATIVE_AI_API_KEY=YOUR-GEMINI-API-KEY
CHAT_MODEL=gemini-3.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# --- Admin ----------------------------------------------------------------
# Comma-separated allowlist of emails permitted into /admin.
ADMIN_EMAILS=mattdenzin@yahoo.com

# --- Site -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
